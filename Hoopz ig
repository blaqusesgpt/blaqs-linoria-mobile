    local function performClick()
        local vs = Camera.ViewportSize
        local cx = vs.X / 2 + (S.XOffsetEnabled and S.XOffset or 0)
        local cy = vs.Y / 2 + S.YOffset
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.wait()
        VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
    end

    local function shootHighArc(Goal, Distance)
        local d = math.floor(Distance + 0.5)
        if d < 20 or d > 73 then return end
        local oldCF, oldCT = Camera.CFrame, Camera.CameraType
        Player:SetAttribute("Power", 85)
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame = CFrame.new(Character.Head.Position, Goal.Position + Vector3.new(0, GetHighArc(d), 0) + GetVelocity() * 0.05)
        task.wait(0.01) performClick() task.wait(0.01)
        Camera.CameraType = oldCT
        Camera.CFrame = oldCF
    end

    local function shootLowArc(Goal, Distance)
        local d = math.floor(Distance + 0.5)
        if d < 20 or d > 73 then return end
        local oldCF, oldCT = Camera.CFrame, Camera.CameraType
        Player:SetAttribute("Power", GetLowArcPower(d))
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame = CFrame.new(Character.Head.Position, Goal.Position + Vector3.new(0, GetLowArc(d), 0) + GetVelocity() * 0.05)
        task.wait(0.01) performClick() task.wait(0.01)
        Camera.CameraType = oldCT
        Camera.CFrame = oldCF
    end

    local function AdjustCameraForJump()
        if not S.AimbotEnabled then return end
        if not IsHoldingBasketball() then return end
        local Goal, Distance = GetEnemyGoal()
        if not Goal then return end
        if S.ArcMode == "High Arc" then shootHighArc(Goal, Distance)
        else shootLowArc(Goal, Distance) end
    end

    Humanoid.StateChanged:Connect(function(_, NewState)
