    AgLockLabel.Position          = UDim2.new(1, -20, 0, 4)
    AgLockLabel.BackgroundTransparency = 1
    AgLockLabel.Text              = "🔓"
    AgLockLabel.TextScaled        = true
    AgLockLabel.ZIndex            = 5
    AgLockLabel.Parent            = AgBtn

    local function updateAgButton()
        if S.AutoGuardEnabled then
            AgStateLabel.Text       = "ON"
            AgStateLabel.TextColor3 = Color3.fromRGB(80, 255, 120)
            TweenService:Create(AgGlow, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 200, 100)}):Play()
            TweenService:Create(AgStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(50, 200, 100)}):Play()
        else
            AgStateLabel.Text       = "OFF"
            AgStateLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            TweenService:Create(AgGlow, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
            TweenService:Create(AgStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(200, 50, 50)}):Play()
        end
    end

    task.spawn(function()
        local t = 0
        while AgBtn and AgBtn.Parent do
            t = t + 0.06
            if not S.AutoGuardEnabled then
                pcall(function()
                    local r = 200 + math.sin(t * 2) * 40
                    local g = 50  + math.sin(t * 2 + 1) * 20
                    AgStroke.Color            = Color3.fromRGB(math.clamp(r,0,255), math.clamp(g,0,255), 80)
                    AgGlow.BackgroundColor3   = Color3.fromRGB(math.clamp(r,0,255), math.clamp(g,0,255), 80)
                end)
            end
            task.wait(0.06)
        end
    end)

    local agDragging, agDragInput, agDragStart, agStartPos = false, nil, nil, nil
    local agInputStartTime, agDidDrag, agIsLocked = 0, false, false
    local agHoldThreshold = 0.5

    AgBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            agInputStartTime = tick()
            agDidDrag = false
            task.delay(agHoldThreshold, function()
                if not agDidDrag then
                    agIsLocked = not agIsLocked
                    AgLockLabel.Text = agIsLocked and "🔒" or "🔓"
                    TweenService:Create(AgBtn, TweenInfo.new(0.1), {Size = UDim2.new(0, 140, 0, 52)}):Play()
                    task.wait(0.12)
                    TweenService:Create(AgBtn, TweenInfo.new(0.1), {Size = UDim2.new(0, 130, 0, 48)}):Play()
                end
            end)
            if not agIsLocked then
                agDragging = true
                agDragStart = input.Position
                agStartPos  = AgGlow.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then agDragging = false end
                end)
            end
        end
    end)

    AgBtn.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            agDragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == agDragInput and agDragging and not agIsLocked then
            local delta = input.Position - agDragStart
            if delta.Magnitude > 5 then agDidDrag = true end
            AgGlow.Position = UDim2.new(
                agStartPos.X.Scale, agStartPos.X.Offset + delta.X,
                agStartPos.Y.Scale, agStartPos.Y.Offset + delta.Y
            )
        end
    end)

    AgBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local held = tick() - agInputStartTime
            agDragging = false
            if held < agHoldThreshold and not agDidDrag then
                S.AutoGuardEnabled = not S.AutoGuardEnabled
                updateAgButton()
                TweenService:Create(AgBtn, TweenInfo.new(0.1, Enum.EasingStyle.Back), {Size = UDim2.new(0, 118, 0, 42)}):Play()
                task.wait(0.1)
                TweenService:Create(AgBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back), {Size = UDim2.new(0, 130, 0, 48)}):Play()
                if S.AutoGuardEnabled then
                    startAutoGuard()
                    Library:Notify("Auto Guard ON | " .. S.GuardMode)
                else
                    stopAutoGuard()
                    Library:Notify("Auto Guard disabled")
                end
            end
        end
    end)

