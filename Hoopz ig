    local cachedJumpCons = {}

    local function cacheExistingJumpCons(hum)
        local list = {}
        pcall(function()
            for _, c in ipairs(getconnections(hum.Jumping)) do
                table.insert(list, c)
            end
        end)
        cachedJumpCons[hum] = list
    end

    local function disableCachedJumpCons(hum)
        local list = cachedJumpCons[hum]
        if not list then return end
        for _, c in ipairs(list) do pcall(function() c:Disable() end) end
    end

    local function enableCachedJumpCons(hum)
        local list = cachedJumpCons[hum]
        if not list then return end
        for _, c in ipairs(list) do pcall(function() c:Enable() end) end
        cachedJumpCons[hum] = nil
    end

    local function setAntiTravel(on)
        local hum = Character:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        if on then
            cacheExistingJumpCons(hum)
            disableCachedJumpCons(hum)
        else
            enableCachedJumpCons(hum)
        end
    end

    -- ============================================================
    --  ANTI FALL  (from working script - invisible box on heads)
    -- ============================================================
    local antiFallThread = nil
    local antiFallBoxes  = {}

    local function startAntiFall()
        if antiFallThread then return end
        antiFallThread = task.spawn(function()
            while S.AntiFallEnabled do
                local myHRP = Character:FindFirstChild("HumanoidRootPart")
                if myHRP then
                    -- collect 3 closest players
                    local sorted = {}
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                            table.insert(sorted, {
                                player = plr,
                                dist   = (myHRP.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                            })
                        end
                    end
                    table.sort(sorted, function(a, b) return a.dist < b.dist end)
                    local closest = {}
                    for i = 1, math.min(3, #sorted) do table.insert(closest, sorted[i].player) end

                    -- remove boxes for players no longer in range
                    for plr in pairs(antiFallBoxes) do
                        local keep = false
                        for _, cp in ipairs(closest) do if plr == cp then keep = true break end end
                        if not keep then antiFallBoxes[plr]:Destroy() antiFallBoxes[plr] = nil end
                    end

                    -- create / update boxes
                    for _, cp in ipairs(closest) do
                        local head = cp.Character:FindFirstChild("Head")
                        if head then
                            if not antiFallBoxes[cp] then
                                local box = Instance.new("Part")
                                box.Name        = "AntiFallBox"
                                box.Size        = Vector3.new(3, 3, 3)
                                box.Transparency = 1
                                box.Anchored    = true
                                box.CanCollide  = true
                                box.Material    = Enum.Material.SmoothPlastic
                                box.CFrame      = head.CFrame
                                box.Parent      = workspace
                                antiFallBoxes[cp] = box
                            else
                                antiFallBoxes[cp].CFrame = head.CFrame
                            end
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end

    local function stopAntiFall()
        S.AntiFallEnabled = false
        if antiFallThread then task.cancel(antiFallThread) antiFallThread = nil end
        for _, box in pairs(antiFallBoxes) do box:Destroy() end
        antiFallBoxes = {}
    end

    -- ============================================================
    --  AUTO DUNK  (from working script - big head method)
    -- ============================================================
    local normalHeadSize = Vector3.new(2, 1, 1)
    local dunkHeadSize   = 50
    local dunkRange      = 30
    local dunkSpeed      = 1000

    local function makeFakeHead(char, realHead)
        local fakeHead = char:FindFirstChild("FakeHead")
        if not fakeHead then
            fakeHead          = realHead:Clone()
            fakeHead.Name     = "FakeHead"
            fakeHead.Size     = normalHeadSize
            fakeHead.CanCollide = false
            fakeHead.Massless = true
            fakeHead.Anchored = false
            fakeHead.Parent   = char
            local weld  = Instance.new("WeldConstraint")
            weld.Part0  = realHead
            weld.Part1  = fakeHead
            weld.Parent = fakeHead
        end
        return fakeHead
    end

    local function updateDunkHead(hasBall)
        local head = Character:FindFirstChild("Head")
        if not head then return end
        local fakeHead = makeFakeHead(Character, head)
        if hasBall and S.AutoDunkEnabled then
            head.Size        = Vector3.new(dunkHeadSize, dunkHeadSize, dunkHeadSize)
            head.Transparency = 1
            head.CanCollide  = false
            head.Massless    = true
            fakeHead.Size    = normalHeadSize
            fakeHead.Transparency = 0
        else
            head.Size        = normalHeadSize
            head.Transparency = 0
            head.CanCollide  = true
            head.Massless    = false
            if fakeHead then fakeHead.Transparency = 1 end
        end
    end

    task.spawn(function()
        while true do
            task.wait(0.05)
            local hasBall = Character:FindFirstChild("Basketball") ~= nil
            updateDunkHead(hasBall)
            if hasBall and S.AutoDunkEnabled then
                local head = Character:FindFirstChild("Head")
                local hoop = workspace:FindFirstChild("Hoop")
                if head and hoop and (head.Position - hoop.Position).Magnitude <= dunkRange then
                    local bv = Instance.new("BodyVelocity")
                    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                    bv.Velocity = (hoop.Position - head.Position).Unit * dunkSpeed
                    bv.Parent   = Character.Basketball
                    game:GetService("Debris"):AddItem(bv, 0.1)
                end
            end
        end
    end)

