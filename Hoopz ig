    local function GetEnemyGoal()
        local CharPos = Character.PrimaryPart and Character.PrimaryPart.Position
        if not CharPos then return nil, math.huge end
        local nearestCourt, nearestCourtDist = nil, math.huge
        for _, container in next, {workspace:FindFirstChild("Courts"), workspace:FindFirstChild("PracticeArea")} do
            if container then
                for _, court in next, container:GetChildren() do
                    for _, Obj in next, court:GetDescendants() do
                        if Obj.Name == "Swish" and Obj.Parent:FindFirstChildOfClass("TouchTransmitter") then
                            local d = (CharPos - Obj.Parent.Position).Magnitude
                            if d < nearestCourtDist then nearestCourtDist = d nearestCourt = court end
                        end
                    end
                end
            end
        end
        if not nearestCourt then return nil, math.huge end
        local hoops = {}
        for _, Obj in next, nearestCourt:GetDescendants() do
            if Obj.Name == "Swish" and Obj.Parent:FindFirstChildOfClass("TouchTransmitter") then
                table.insert(hoops, Obj.Parent)
            end
        end
        if #hoops == 0 then return nil, math.huge end
        local enemyHoop, maxDist = nil, -math.huge
        for _, hoop in ipairs(hoops) do
            local d = (CharPos - hoop.Position).Magnitude
            if d > maxDist then maxDist = d enemyHoop = hoop end
        end
        return enemyHoop, maxDist
    end

