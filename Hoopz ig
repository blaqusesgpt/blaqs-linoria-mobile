    --  AUTO GUARD  (FIXED - guards closest player properly)
    -- ============================================================
    local autoGuardRunning = false
    local autoGuardThread  = nil

    -- returns closest player regardless of ball, for Guard Player mode
    local function getClosestPlayer()
        local myHRP = Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil end
        local closest, closestDist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character then
                local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local d = (myHRP.Position - hrp.Position).Magnitude
                    local range = S.NearBallMode and 20 or 80
                    if d < closestDist and d <= range then
                        closestDist = d
                        closest     = plr
                    end
                end
            end
        end
        return closest
    end

    -- returns closest player holding ball, for Guard Ball mode
    local function getClosestBallHandler()
        local myHRP = Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil end
        local closest, closestDist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Basketball") then
                local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local d = (myHRP.Position - hrp.Position).Magnitude
                    local range = S.NearBallMode and 20 or 80
                    if d < closestDist and d <= range then
                        closestDist = d
                        closest     = plr
                    end
                end
            end
        end
        return closest
    end

    local function agWalkTo(pos)
        local hum = Character:FindFirstChild("Humanoid")
        if not hum then return end
        if not pos then hum:Move(Vector3.zero, false) return end
        hum:MoveTo(pos)
    end

    local function startAutoGuard()
        if autoGuardRunning then return end
        autoGuardRunning = true
        autoGuardThread = task.spawn(function()
            while S.AutoGuardEnabled do
                task.wait(0.15)

                if Character:FindFirstChild("Basketball") then
                    -- I have the ball, stop guarding
                    agWalkTo(nil)
                else
                    local target = nil

                    if S.GuardMode == "Guard Player" then
                        -- guard the closest player (anyone)
                        target = getClosestPlayer()
                    else
                        -- guard the closest ball carrier
                        target = getClosestBallHandler()
                    end

                    if target and target.Character then
                        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
                        local hum2 = target.Character:FindFirstChild("Humanoid")
                        if hrp and hum2 then
                            -- walk slightly in front of them based on prediction
                            local predicted = hrp.Position + (hum2.MoveDirection * S.GuardPrediction)
                            agWalkTo(predicted)
                        end
                    else
                        agWalkTo(nil)
                    end
                end
            end
            agWalkTo(nil)
            autoGuardRunning = false
        end)
    end

    local function stopAutoGuard()
        S.AutoGuardEnabled = false
        agWalkTo(nil)
        if autoGuardThread then task.cancel(autoGuardThread) autoGuardThread = nil end
        autoGuardRunning = false
    end

