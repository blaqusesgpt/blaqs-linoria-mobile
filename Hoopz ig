    local speedConn
    local function applySpeed()
        if speedConn then speedConn:Disconnect() speedConn = nil end
        if not S.SpeedEnabled then return end
        local hrp = Character:FindFirstChild("HumanoidRootPart")
        speedConn = RunService.Heartbeat:Connect(function(dt)
            if not S.SpeedEnabled or not Humanoid or not hrp then return end
            local move = Humanoid.MoveDirection
            if move.Magnitude > 0 then
                local scaled = (math.clamp(S.SpeedBoost, 0, 5) / 10) * 10
                Humanoid:Move(move.Unit, true)
                hrp.CFrame = hrp.CFrame + move.Unit * scaled * dt
            end
        end)
    end

    -- ============================================================
    --  MAGNET
    -- ============================================================
    local MagConn, _lastMagTime = nil, 0
    local function runMag()
        if MagConn then MagConn:Disconnect() MagConn = nil end
        MagConn = RunService.Heartbeat:Connect(function()
            if not S.MagnetEnabled then return end
            local now = tick()
            if now - _lastMagTime < 0.05 then return end
            _lastMagTime = now
            local hrp = Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local parts = workspace:GetPartBoundsInBox(hrp.CFrame, Vector3.new(S.MagnetDistance, S.MagnetDistance, S.MagnetDistance))
            local nearest, minDist = nil, S.MagnetDistance
            for _, part in ipairs(parts) do
                if part:IsA("BasePart") and part.Name:lower() == "ball" then
                    local d = (part.Position - hrp.Position).Magnitude
                    if d <= minDist then minDist = d nearest = part end
                end
            end
            if nearest then
                pcall(function()
                    firetouchinterest(hrp, nearest, 0)
                    task.wait(0.05)
                    firetouchinterest(hrp, nearest, 1)
                end)
            end
        end)
    end
    local function stopMag()
        if MagConn then MagConn:Disconnect() MagConn = nil end
    end

